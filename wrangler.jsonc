{
  "name": "vsl-player",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "VSL_KV",
      "id": "{{SEU_KV_NAMESPACE_ID}}"
    }
  ],
  "vars": {
    "BUNNY_LIBRARY_ID": "676737",
    "BUNNY_API_KEY": "SUA_BUNNY_API_KEY"
  }
}
